# ============================================================
# SuDS Enviro Configurator - Environment Variables
# Copy this file to .env.local and fill in all values
# Do NOT commit .env.local to source control
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Get these from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Site URL ────────────────────────────────────────────────
# Development: http://localhost:3000
# Production: your Vercel domain (e.g. https://suds-enviro.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Admin ───────────────────────────────────────────────────
# Password for accessing the /admin dashboard
# Choose a strong password - this gates all admin functionality
ADMIN_PASSWORD=SuDSEnviro2026

# ── Reviewer ────────────────────────────────────────────────
# Password for the feedback review tool (/review)
# Falls back to ADMIN_PASSWORD if not set
REVIEWER_PASSWORD=

# ── Email (Phase 2 - Optional) ──────────────────────────────
# Resend API key for enquiry email notifications
# Get from resend.com > API Keys
# RESEND_API_KEY=

# Admin email - where enquiry notifications are sent
ADMIN_EMAIL=hello@sudsenviro.com
